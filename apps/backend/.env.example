# Casyomax backend — environment variables
# Copy this file to .env and fill in real values. Do NOT commit .env.

# --- Server ---
PORT=5000

# --- PostgreSQL (the `caresync` schema is hardcoded in src/config/db.js) ---
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=5432
# For the apply_schema_schedule.js one-off script only:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# --- Auth ---
JWT_SECRET=

# --- AI provider for chat / AI assistant ---
# Use "azure" for production, or "ollama" for local LLM testing.
AI_PROVIDER=azure

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_ID=gpt-4o-care-sync

# --- Ollama (used when AI_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_MS=120000
# Set false for simple local chat with a model that does not support tools.
OLLAMA_ENABLE_TOOLS=true
# auto sends tools only for tool-like prompts; use always/never to override.
OLLAMA_TOOL_MODE=auto

# --- Azure Speech (for voice transcribe + TTS) ---
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# --- Azure Communication Services (for transactional email) ---
AZURE_COMMUNICATION_CONNECTION_STRING=
SENDER_EMAIL_ADDRESS=

# --- Optional external services ---
AZURE_MAPS_KEY=
BING_SEARCH_KEY=
AZURE_AI_SERVICES_KEY=
