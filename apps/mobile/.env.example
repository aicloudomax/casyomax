# Casyomax mobile — environment variables
# Copy this file to .env and fill in real values. Do NOT commit .env.
# All vars must be prefixed with EXPO_PUBLIC_ to be readable from app code.

# Where the mobile app talks to the backend.
# - For local dev with an Android emulator / physical device on your LAN:
#     EXPO_PUBLIC_API_BASE_URL=http://<YOUR-LAN-IP>:5000/api
# - For production, point at the Azure App Service:
#     EXPO_PUBLIC_API_BASE_URL=https://caresync-backend-ewfcajcdbka3dsag.centralindia-01.azurewebsites.net/api
EXPO_PUBLIC_API_BASE_URL=

# Azure Speech (client-side STT/TTS).
# !! ROTATE the key that previously lived in the committed .env file before reuse.
EXPO_PUBLIC_AZURE_SPEECH_KEY=
EXPO_PUBLIC_AZURE_SPEECH_REGION=centralindia
